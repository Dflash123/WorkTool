# MMORPG Monster Reference System — 환경변수 설정
# 이 파일을 복사하여 .env 로 저장 후 실제 값을 입력하세요
# .env 파일은 절대 git에 커밋하지 않습니다

# Claude API (패턴 추출용)
CLAUDE_API_KEY=your_claude_api_key_here

# YouTube Data API v3 (영상 검색/수집용)
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI API (Claude API fallback용, 선택사항)
OPENAI_API_KEY=your_openai_api_key_here

# 수집 설정
YOUTUBE_MIN_VIEWS=10000
YOUTUBE_COMMENT_SAMPLE_SIZE=20
LLM_MODEL=claude-3-5-sonnet-20241022
